# ─────────────────────────────────────────────────────────────
# NamasteStay — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file → rename it to  .env
#   2. Fill in your real values below
#   3. NEVER commit your real .env file to GitHub
# ─────────────────────────────────────────────────────────────


# ── DATABASE ──────────────────────────────────────────────────
# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Drivers
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/namastestay
ATLASDB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/namastestay


# ── SESSION ───────────────────────────────────────────────────
# A long random string used to sign session cookies
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET=your_super_secret_key_here


# ── CLOUDINARY (Image Storage) ────────────────────────────────
# Get all 3 values from: https://cloudinary.com → Dashboard
USE_CLOUDINARY=true
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret
